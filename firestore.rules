rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Por ahora: solo usuarios autenticados pueden leer/escribir
    // Cambia estas reglas según tus necesidades de seguridad

    match /projects/{docId} {
      allow read, write: if request.auth != null;
    }
    match /activities/{docId} {
      allow read, write: if request.auth != null;
    }
    match /history/{docId} {
      allow read, write: if request.auth != null;
    }
    match /alerts/{docId} {
      allow read, write: if request.auth != null;
    }
    match /users/{docId} {
      allow read, write: if request.auth != null;
    }
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
