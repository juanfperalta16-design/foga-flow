rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Solo usuarios autenticados (cuentas creadas a mano en Firebase Console)
    // pueden leer/escribir. No hay roles/permisos todavía: cualquier cuenta
    // logueada puede ver y editar todo, igual que la app antes de esta migración.

    match /proyectos/{docId} {
      allow read, write: if request.auth != null;
    }
    match /actividades/{docId} {
      allow read, write: if request.auth != null;
    }
    match /alertas/{docId} {
      allow read, write: if request.auth != null;
    }
    match /historial/{docId} {
      allow read, write: if request.auth != null;
    }
    match /responsables/{docId} {
      allow read, write: if request.auth != null;
    }
    match /departamentos_config/{docId} {
      allow read, write: if request.auth != null;
    }
    match /prospectos/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
